{
  "name": "@mizan/core",
  "version": "0.1.0",
  "type": "module",
  "description": "Runtime-neutral TypeScript authorization decision layer",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
